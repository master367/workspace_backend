# Database settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=workspace_db
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

# Async Database URL (for SQLAlchemy)
# For local dev: 127.0.0.1:5433
# For docker: db:5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5433/workspace_db

# Security
# Generate random key: openssl rand -hex 32
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
